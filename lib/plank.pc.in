prefix=@prefix@
exec_prefix=@exec_prefix@
libdir=@libdir@
includedir=@includedir@
pkgdatadir=@datarootdir@/plank

Name: Plank
Description: Generic dock library of Plank
Version: @PACKAGE_VERSION@
Requires: cairo gee-0.8 glib-2.0 >= 2.70 gio-2.0 gobject-2.0 gdk-3.0 gdk-pixbuf-2.0 gtk+-3.0 >= 3.22 libbamf3 libwnck-3.0 >= 43
Libs: -L${libdir} -lplank
Cflags: -I${includedir}/plank -DWNCK_I_KNOW_THIS_IS_UNSTABLE
